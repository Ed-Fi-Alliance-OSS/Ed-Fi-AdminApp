meta {
  name: environments/create v3 single-tenant - OK (201)
  type: http
  seq: 1
  tags: Environments
}

post {
  url: {{BASE_URL}}/sb-environments
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{ACCESS_TOKEN}}
}

body:json {
  {
    "name": "AC-526 V3 Single Tenant Validation",
    "version": "v3",
    "startingBlocks": false,
    "isMultitenant": false,
    "adminApiUrl": "https://localhost/odsv7-adminv3-single-adminapi",
    "odsApiDiscoveryUrl": "https://localhost/odsv7-adminv3-single-api"
  }
}

vars:post-response {
  v3SingleEnvId: res.body.id
}

tests {
  test("environments/create v3 single-tenant - status is 2xx", function() {
    const status = res.getStatus();
    expect(status).to.be.within(200, 299);
  });

  test("environments/create v3 single-tenant - response includes id and syncQueue", function() {
    const body = res.getBody();
    expect(body).to.have.property("id");
    expect(body).to.have.property("syncQueue");
  });
}
