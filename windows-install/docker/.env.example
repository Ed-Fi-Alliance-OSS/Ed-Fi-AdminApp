# Postgres superuser (used by docker-entrypoint and the init script)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-postgres-superuser

# Database AdminApp connects to (example name from Ed-Fi docs)
ADMIN_APP_DB_NAME=sbaa

# Dedicated AdminApp role (used by AdminApp DB_USERNAME / DB_PASSWORD)
ADMIN_APP_DB_USER=edfiadminapp
ADMIN_APP_DB_PASSWORD=changeme-adminapp-user

# Host port. Override if 5432 is already taken on the host.
POSTGRES_PORT_EXPOSED=5432

# Host interface the DB port binds to. Defaults to 127.0.0.1 (loopback only) so
# the database is not reachable from other hosts. Set to 0.0.0.0 to expose it on
# all interfaces for remote access -- only do this behind a firewall and with TLS
# (this stack already serves SSL; require sslmode=verify-full on remote clients).
POSTGRES_BIND_HOST=127.0.0.1
