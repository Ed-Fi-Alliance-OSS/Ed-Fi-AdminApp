# =============================================================================
# Azure Container Apps Deployment Configuration
# =============================================================================
# Copy this file to .env.azure and customize values before running deploy.sh
# or deploy.ps1.
# =============================================================================

# --- Azure Resource Settings ---
AZURE_LOCATION=eastus
AZURE_STORAGE_ACCOUNT=edfiadminappstore
# Azure Container Registry name (leave empty to use Docker Hub images)
ACR_NAME=

# --- Container Registry ---
# Set to your ACR login server (e.g., myacr.azurecr.io) or docker.io for Docker Hub
REGISTRY_SERVER=docker.io

# --- AdminApp Container Images ---
# If using Docker Hub (REGISTRY_SERVER=docker.io):
ADMINAPP_API_IMAGE=edfialliance/adminapp-api:pre
ADMINAPP_FE_IMAGE=edfialliance/adminapp-fe:pre

# --- Common Database Settings ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeMeToAStrongPassword!
ADMIN_APP_DB_NAME=sbaa
DB_ENGINE=pgsql
DB_SSL=false
DB_TRUST_CERTIFICATE=false
DB_TTL_IN_MINUTES=120

# --- MSSQL (optional, set USE_MSSQL=true to deploy) ---
USE_MSSQL=false
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
MSSQL_IMAGE_TAG=2022-latest

# --- Connection Pooling ---
NPG_POOLING_ENABLED=true
NPG_API_MAX_POOL_SIZE_ODS=20
NPG_API_MAX_POOL_SIZE_ADMIN=20
NPG_API_MAX_POOL_SIZE_SECURITY=20
NPG_API_MAX_POOL_SIZE_MASTER=20

# --- Ed-Fi Settings ---
TPDM_ENABLED=true

# --- BASE_URL ---
# This is set automatically after nginx is deployed (nginx FQDN).
# If you have a custom domain, set it here and the script will use it.
# Example: BASE_URL=https://edfi.yourdomain.com
BASE_URL=

# --- Ed-Fi ODS/API v7.x Images ---
ODS_DB_IMAGE_7X=ods-api-db-ods-minimal
ODS_DB_TAG_7X=v7.3
ODS_API_TAG_7X=v7.3
ADMIN_DB_TAG_7X=pre
ADMIN_API_TAG_7X=pre

V7_MULTI_API_VIRTUAL_NAME=v7-multi-api
V7_MULTI_ADMINAPI_VIRTUAL_NAME=v7-multi-adminapi
V7_SINGLE_API_VIRTUAL_NAME=v7-single-api
V7_SINGLE_ADMIN_API_VIRTUAL=v7-single-adminapi

MULTITENANCY_ENABLED=true
PAGING_OFFSET=0
PAGING_LIMIT=25
ENABLE_APPLICATION_RESET_ENDPOINT=true
SWAGGER_DEFAULT_TENANT=tenant1

# Generate a new encryption key: openssl rand -base64 32
ODS_CONNECTION_STRING_ENCRYPTION_KEY=vLgnKf+MyoAsEmeGsh+n+rKRN1bGS8s1b0eCo6zc5+o=

# --- Ed-Fi ODS/API v6.x Images ---
ODS_DB_IMAGE_6X=ods-api-db-ods
ODS_DB_TAG_6X=v2.3.5
ODS_API_TAG_6X=v2.3.5
ADMIN_DB_TAG_6X=v1.4.3
ADMIN_TAG_6X=pre

V6_ODS_VIRTUAL_NAME=v6-api
V6_ADMIN_API_VIRTUAL_NAME=v6-adminapi
ODS_API_VERSION_6X=6.1

# --- Admin API Signing Key ---
# Generate a new signing key: openssl rand -base64 32
SIGNING_KEY=v+R+atm4BwN+Y8EavGPqGs3Gt1kBX3qEBZmwyZBG95I=

# --- Keycloak ---
KEYCLOAK_TAG=26.1
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=ChangeThisKeycloakPassword!
KC_LOG_CONSOLE_LEVEL=error
KEYCLOAK_EDFIADMINAPP_CLIENT_SECRET=big-secret-123
KEYCLOAK_EDFIADMINAPP_DEV_CLIENT_SECRET=big-secret-123

# --- Yopass ---
USE_YOPASS=true

# --- Frontend Configuration ---
VITE_OIDC_ID=1
VITE_BASE_PATH=/adminapp/
VITE_HELP_GUIDE=https://docs.ed-fi.org/reference/admin-app-v4
VITE_CONTACT=https://community.ed-fi.org
VITE_APPLICATION_NAME="Ed-Fi Admin App"

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
